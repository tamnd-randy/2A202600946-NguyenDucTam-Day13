{
  "provider": "openai",
  "model": "openai/gpt-oss-120b:free",
  "model_price_tier": "economy",
  "max_steps": 6,
  "loop_guard": true,
  "temperature": 0.1,
  "context_size": 2,
  "verbose_system": false,
  "timeout_ms": 0,
  "max_completion_tokens": 2000,
  "retry": {
    "enabled": true,
    "max_attempts": 3,
    "backoff_ms": 100
  },
  "cache": {
    "enabled": true
  },
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 1,
  "tool_error_rate": 0.18,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": false,
  "self_consistency": 1,
  "tool_budget": 3
}
